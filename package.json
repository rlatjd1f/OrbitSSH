{
  "name": "orbit-ssh",
  "productName": "Orbit SSH",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "rebuild:native": "electron-rebuild -f -w node-pty",
    "desktop:prod": "npm run build && electron .",
    "preview": "vite preview",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "latest",
    "node-pty": "^1.1.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@electron/rebuild": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "wait-on": "latest"
  }
}

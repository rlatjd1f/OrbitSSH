{
  "name": "orbit-ssh",
  "productName": "Orbit SSH",
  "private": true,
  "version": "0.1.0",
  "description": "A customizable desktop SSH manager with tabbed terminals and split panes.",
  "author": "rlatjd1f",
  "repository": "https://github.com/rlatjd1f/OrbitSSH.git",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "desktop": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "rebuild:native": "electron-builder install-app-deps",
    "desktop:prod": "npm run build && electron .",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rlatjd1f.orbitssh",
    "productName": "Orbit SSH",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "artifactName": "OrbitSSH-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "latest",
    "node-pty": "^1.1.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.15.3",
    "wait-on": "latest"
  }
}
